{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Palimpsest",
  "version": "0.6.5",
  "identifier": "com.palimpsest.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Palimpsest",
        "width": 1200,
        "height": 800,
        "minWidth": 640,
        "minHeight": 400,
        "hiddenTitle": true,
        "titleBarStyle": "Overlay"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["pdf"],
        "mimeType": "application/pdf",
        "role": "Editor",
        "description": "PDF Document"
      }
    ]
  }
}
